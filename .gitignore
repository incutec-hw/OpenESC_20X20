# macOS
.DS_Store

# KiCad backup and autosave
*-backups/
*.bak
*.000
_autosave-*
*~
\#auto_saved_files#

# KiCad generated/local
*.kicad_prl
*.kicad_dru
*.kicad_sch-bak
*.kicad_pcb-bak
*.lck
*.net
*.rpt
*.tmp
fp-info-cache
replicate_layout.log

# KiCad local history
**/.history/

# 3D exports (not library files)
**/.step
**/*.glb

# Production output (generated, re-exportable)
**/production/

# Fabrication toolkit config
fabrication-toolkit-options.json

# Python
__pycache__/
*.pyc

# Claude
.claude/
CLAUDE.md

# Repo-specific
OpenFC/

# Internal docs — keep markdowns local; README is the public doc
*.md
!README.md

# Archive of stale design docs and unused scripts (local reference only)
docs/
